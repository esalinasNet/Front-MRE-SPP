@{
    Layout = "_Layout";
}
@using Microsoft.Extensions.Configuration
@using Microsoft.Extensions.Options
@inject IOptions<MRE.WebSISA.Pages.Core.PassportSettings> passportSettings

<input type="hidden" value="@Model.RutaApi" id="hidAPI" />
<input type="hidden" value="@Model.RutaWeb" id="hidWEB" />


<input type="hidden" value="@passportSettings.Value.llave" id="hidApik" />
<input type="hidden" value="@passportSettings.Value.codigo" id="hidApp" />


<script>

    const basePath = {
        sgeoAPi: document.querySelector("#hidAPI").value,
        sgeoWEB: document.querySelector("#hidWEB").value
    }
    const __paramApi = {
        key: document.querySelector("#hidApik").value,
        code: document.querySelector("#hidApp").value
    }
    const K_PARAM_SAFE = {
        _kUser: "@Model._kUser",
        _vUser: "@Model._vUser",
        _kPass: "@Model._kPass",
        _vPass: "@Model._vPass",
        _enabled: "@Model._enabled"
    }
</script>
<script src="~/app/general/configproto.js" type="text/javascript"></script>