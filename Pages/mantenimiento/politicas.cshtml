@page
@model MRE.Pages.mantenimiento.politicasModel
@{
}
<script src="~/app/services/service.anio.js"></script>
<script src="~/app/services/service.politicas.js"></script>
<script src="~/app/pages/mantenimiento/politicas.js"></script>
<style>
    .container-fluid {
        width: 100% !important;
    }

    .container {
        width: 100% !important;
    }
</style>

<div>
    <div class="row">
        <div class="col-md-12">
            <h3 class="titulo">Mantenimiento de Políticas <i class="bi-newspaper"></i></h3>
        </div>

    </div>

    <div class="accordion" id="accordionExample">
        <div class="card">
            <div class="card-header" id="headingOne">
                <div class="row">
                    <div class="col-md-9   ">
                        <h5 class="mb-0">
                            Búsqueda avanzada
                            <button class="btn btn-light btn-sm " type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                                <i class="bi-arrow-down-square-fill"></i>
                            </button>
                        </h5>
                    </div>
                    <div class="col-md-3 text-end   ">
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button class="btn btn-danger  btn-sm" title="buscar" id="btnBuscar">
                                <i class="bi-search"></i> Buscar
                            </button>
                            <button class="btn  btn-sm btn-dark" id="btnLimpiar">
                                <i class="bi-arrow-clockwise"></i> Limpiar
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="collapseOne" class="collapse" aria-labelledby="headingOne" data-bs-parent="#accordionExample">
                <div class="card-body">
                    <div class="row   m-b-a">
                        <div class="col-md-2">
                            <label>Año de Programación</label>
                            <select id="cboAnioFiltro" class="form-control">
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label>Política </label>
                            <input class="form-control" type="text" id="txtPoliticasFiltro">
                        </div>
                        <div class="col-md-3">
                            <label>Descripción</label>
                            <input class="form-control" type="text" id="txtDescripcionFiltro">
                        </div>
                        <div class="col-md-3">
                            <label>Estaddo</label>
                            <input class="form-control" type="text" id="txtEstadoFiltro">
                        </div>
                        <div class="col-md-2">
                            <label>Situación</label>
                            <select id="cboSituacionFiltro" class="form-control">
                                <option value="">Todos</option>
                                <option value="1">Activo</option>
                                <option value="0">Inactivo</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>


            <div class="container-fluid tablelist">
                <div class="row listpro">
                    <div class="col-md-6">
                        <h5 class="titwhite">
                            Resultados de búsqueda
                        </h5>
                    </div>
                    <div class="col-md-6 text-end">
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button class="btn btn-light   mt-2  btn-sm" id="btnAgregar" title="Agregar nuevo">
                                <i class="bi bi-file-earmark-plus-fill"></i> Nuevo Registro
                            </button>
                        </div>
                    </div>
                </div>


                <div class="row">
                    <div class="col-md-12">
                        <table id="grid" class="table table-striped   table-hover nowrap" style="width:100%">
                            <thead class="thead-uarm">
                                <tr>
                                    <th>N°</th>
                                    <th>Año</th>

                                    <th>Política</th>
                                    <th>Descripción Política</th>

                                    <th>Objetivo</th>
                                    <th>Descripción Objetivo</th>

                                    <th>Lineamiento</th>
                                    <th>Descripción Lineamiento</th>

                                    <th>Servicio</th>
                                    <th>Descripción Servicio</th>

                                    <th>Estado</th>
                                    <th>Activo</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>


            </div>
        </div>
    </div>

    <div class="modal fade" id="modalRegistro" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-menu">
                    <h4 class="modal-title" id="mdlTitle">Registrar nuevo</h4>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" title="Cerrar ventana"></button>
                </div>
                <div class="modal-body">
                    <fieldset class="border rounded-3 p-3">
                        <legend class="float-none w-auto px-3"> Datos de la Política</legend>
                        <div class="row">
                            <input type="hidden" id="flagEdit">
                            <input type="hidden" id="hcodigo">
                            <div class="col-md-3">
                                <label>Año Presupuestal </label> <label style="color:red">(*)</label>
                            </div>
                            <div class="col-md-9">
                                <select id="cboAnio" class="form-select"> </select>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-3">
                                <label>Polítca </label><label style="color:red">(*)</label>
                            </div>
                            <div class="col-md-9">                                
                                <input type="text" class="form-control" id="txtPoliticas" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3">
                                <label>Descripción Polítca</label><label style="color:red">(*)</label>
                            </div>
                            <div class="col-md-9">                                
                                <input type="text" class="form-control" id="txtDescripcionPoliticas" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-3">
                                <label>Objetivo Prioritarios: </label><label style="color:red">(*)</label>
                            </div>
                            <div class="col-md-9">                                
                                <input type="text" class="form-control" id="txtObjetivo" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3">
                                <label>Descripción Objetivo Prioritarios:</label><label style="color:red">(*)</label>
                            </div>
                            <div class="col-md-9">                                
                                <input type="text" class="form-control" id="txtDescripcionObjetivo" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-3">
                                <label>Lineamiento </label><label style="color:red">(*)</label>
                            </div>
                            <div class="col-md-9">                                
                                <input type="text" class="form-control" id="txtLineamiento" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3">
                                <label>Descripción Lineamiento</label><label style="color:red">(*)</label>
                            </div>
                            <div class="col-md-9">                                
                                <input type="text" class="form-control" id="txtDescripcionLineamiento" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-3">
                                <label>Servicio </label><label style="color:red">(*)</label>
                            </div>
                            <div class="col-md-9">                                
                                <input type="text" class="form-control" id="txtServicio" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3">
                                <label>Descripción Servicio</label><label style="color:red">(*)</label>
                            </div>
                            <div class="col-md-9">                                
                                <input type="text" class="form-control" id="txtDescripcionServicio" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-3">
                                <label>Estado </label>
                            </div>
                            <div class="col-md-9">                                
                                <input type="text" class="form-control" id="txtEstado" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3">
                                <label>Activo</label>
                            </div>
                            <div class="col-md-9">                                
                                <select id="cboActivo" class="form-select">
                                    <option value="1">SÍ</option>
                                    <option value="0">NO</option>
                                </select>
                            </div>
                        </div>
                        <div class="row" style="padding-top: 10px">
                            <br />
                            <label style="color:red">Datos Obligatorios (*)</label>
                        </div>
                    </fieldset>

                </div>
                <div class="modal-footer">
                    <button type="button" id="btnGrabar" class="btn btn-primary"><i class="bi bi-check-lg"></i> Grabar</button>
                    <button type="button" id="btnCerrar" class="btn btn-outline-dark"><i class="bi bi-x-lg"></i> Cerrar</button>
                </div>
            </div>
        </div>
    </div>

</div>
