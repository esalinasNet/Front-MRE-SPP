@page
@model MRE.Pages.mantenimiento.catalogoModel
@{
}
<script src="~/app/services/service.catalogo.js"></script>
<script src="~/app/pages/mantenimiento/catalogo.js"></script>
<style>
    .container-fluid {
        width: 100% !important;
    }

    .container {
        width: 100% !important;
    }
</style>

<div>
    <div class="row">
        <div class="col-md-12">
            <h3 class="titulo">Mantenimiento Catálogo <i class="bi-newspaper"></i></h3>
        </div>
       
    </div>

    <div class="accordion" id="accordionFiltro">
        <div class="card">
            <div class="card-header  " id="headingOne">
                <div class="row">
                    <div class="col-md-6   ">
                        <h5 class="mb-0">
                            Búsqueda avanzada
                            <button class="btn btn-light btn-sm " type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                                <i class="bi-arrow-down-square-fill"></i>
                            </button>
                        </h5>
                    </div>
                    <div class="col-md-6 text-end   ">
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">

                            <button class="btn btn-sm  btn-danger  " title="buscar" id="btnBuscar">
                                <i class="bi-search"></i> Buscar
                            </button>
                            <button class="btn  btn-sm btn-dark" id="btnLimpiar">
                                <i class="bi-arrow-clockwise"></i> Limpiar
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="collapseOne" class="collapse" aria-labelledby="headingOne" data-bs-parent="#accordionFiltro">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3  m-b-a ">
                            <label>Descripción</label>
                            <input class="form-control" type="text" id="txtDescripcionFiltro">
                        </div>
                    </div>
                </div>
            </div>
            
                    <div class="container-fluid tablelist">
                        
                        <div class="row listpro">
                                <div class="col-md-6">
                                  <h5 class="titwhite">
                                        Resultados de búsqueda
                                    </h5>
                                </div>
                                 <div class="col-md-6 text-end ">
                                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                    <button class="btn btn-sm btn-light   mt-2" id="btnAgregar" title="Agregar nuevo registro">
                                            <i class="bi bi-clipboard-plus-fill"></i> Agregar Registro
                                        </button>
                                    </div>
                                </div>
                        </div>
                       
                        <div class="row">
                        <table id="grid" class="table table-striped   table-hover nowrap " style="width:100%">
                            <thead class="thead-uarm ">
                                <tr>

                                    <th>N°</th>
                                    <th>Descripción</th>
                                    <th>Código Cátalogo</th>
                                    <th>Es mantenible</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                        </div>

                    </div>
            
   

        </div>
    </div>

    <div class="modal fade" id="modalRegistro" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog  modal-dialog-scrollable">
          
                <div class="modal-content">
                    <div class="modal-header">
                        <h4 class="modal-title" id="mdlTitle"></h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" title="Cerrar ventana"></button>
                    </div>
                    <div class="modal-body">
                    <fieldset class="border rounded-3 p-3">
                        <legend class="float-none w-auto px-3"> Datos de catálogo  </legend>

                            <div class="row">
                                <input type="hidden" id="flagEdit">
                                <input type="hidden" id="hcodigo">
                                <div class="col-md-12">
                                    <label for="txtDescripcionNuevo" class="form-label">Descripción</label>
                                    <input type="text" class="form-control" id="txtDescripcionNuevo" required />
                                    <div class="invalid-feedback">
                                        campo requerido.
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-12">
                                    <label>Codigo catálogo</label>
                                    <input type="text" onkeypress="return soloNumeros(event)" class="form-control" id="txtCodigoCatalogonNuevo" />
                                </div>
                            </div>
                            <br />
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="custom-control custom-switch">
                                        <input type="checkbox" class="custom-control-input" id="rbSi">
                                        <label class="custom-control-label" for="rbSi">Es mantenible</label>
                                    </div>
                                </div>
                            </div>

                        </fieldset>
                    </div>
                    <div class="modal-footer">
                        <button type="button" id="btnGrabar" class="btn btn-danger"><i class="bi bi-check-lg"></i> Grabar</button>
                        <button type="button" id="btnCerrar" class="btn btn-dark"><i class="bi bi-x-lg"></i> Cerrar</button>
                    </div>
                </div>
             
        </div>
    </div>

</div>