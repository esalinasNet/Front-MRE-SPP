@page
@model MRE.Pages.mantenimiento.categoriapresupuestalModel
@{
}

<script src="~/app/services/service.anio.js"></script>
<script src="~/app/services/service.categoriapresupuestal.js"></script>
<script src="~/app/pages/mantenimiento/categoriapresupuestal.js"></script>
@* <script src="~/app/services/service.accionesei_centro_costos.js"></script> *@
<script src="~/app/services/service.accionesinstitucionales.js"></script>
@* <script src="~/app/services/service.centrocostos.js"></script>
<script src="~/app/pages/mantenimiento/centrocostos.js"></script>  *@
<style>
    .container-fluid {
        width: 100% !important;
    }

    .container {
        width: 100% !important;
    }
</style>

<div>
    <div class="row">
        <div class="col-md-12">
            <h3 class="titulo">Categoría Presupuestal con AEI <i class="bi-newspaper"></i></h3>
        </div>

    </div>

    <div class="accordion" id="accordionExample">
        <div class="card">
            <div class="card-header" id="headingOne">
                <div class="row">
                    <div class="col-md-9   ">
                        <h5 class="mb-0">
                            Búsqueda avanzada
                            <button class="btn btn-light btn-sm " type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                                <i class="bi-arrow-down-square-fill"></i>
                            </button>
                        </h5>
                    </div>
                    <div class="col-md-3 text-end   ">
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button class="btn btn-danger  btn-sm" title="buscar" id="btnBuscar">
                                <i class="bi-search"></i> Buscar
                            </button>
                            <button class="btn  btn-sm btn-dark" id="btnLimpiar">
                                <i class="bi-arrow-clockwise"></i> Limpiar
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="collapseOne" class="collapse" aria-labelledby="headingOne" data-bs-parent="#accordionExample">
                <div class="card-body">
                    <div class="row   m-b-a">
                        <div class="col-md-2">
                            <label>Año de Programación</label>
                            <select id="cboAnioFiltro" class="form-control">
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label>Codigo Presupuestal </label>
                            <input class="form-control" type="text" id="txtPresupuestalFiltro">
                        </div>
                        <div class="col-md-2">
                            <label>Descripción Presupuestal</label>
                            <input class="form-control" type="text" id="txtDescripcionFiltro">
                        </div>
                        @*   <div class="col-md-2">
                        <label>Codigo Prioritarios</label>
                        <input class="form-control" type="text" id="txtPrioritariosFiltro">
                        </div> *@
                        <div class="col-md-2">
                            <label>Estado</label>
                            <input class="form-control" type="text" id="txtEstadoFiltro">
                        </div>
                        <div class="col-md-2">
                            <label>Situación</label>
                            <select id="cboSituacionFiltro" class="form-control">
                                <option value="">Todos</option>
                                <option value="1">Activo</option>
                                <option value="0">Inactivo</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>


            <div class="container-fluid tablelist">
                <div class="row listpro">
                    <div class="col-md-6">
                        <h5 class="titwhite">
                            Resultados de búsqueda
                        </h5>
                    </div>
                    <div class="col-md-6 text-end">
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button class="btn btn-light   mt-2  btn-sm" id="btnAgregar" title="Agregar nuevo">
                                <i class="bi bi-file-earmark-plus-fill"></i> Nuevo Registro
                            </button>
                        </div>
                    </div>
                </div>


                <div class="row">
                    <div class="col-md-12">
                        <table id="grid" class="table table-striped   table-hover nowrap" style="width:100%">
                            <thead class="thead-uarm">
                                <tr>
                                    <th>N°</th>
                                    <th>Año</th>

                                    <th>Codigo Presupuestal</th>
                                    <th>Descripción Presupuestal</th>
                                    
                                    @* <th>Cidogo AEI</th>
                                    <th>Descripción AEI</th> *@

                                    <th>N° de AEI Asociados</th>

                                    <th>Estado</th>
                                    <th>Activo</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>


            </div>
        </div>
    </div>

    <div class="modal fade" id="modalRegistro" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-menu">
                    <h4 class="modal-title" id="mdlTitle">Registrar nuevo</h4>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" title="Cerrar ventana"></button>
                </div>
                <div class="modal-body">
                    <fieldset class="border rounded-3 p-3">
                        @* <legend class="float-none w-auto px-3"> Datos - Categoría Presupuestal con AEI</legend> *@
                        @* <div class="row">
                            <input type="hidden" id="flagEdit">
                            <input type="hidden" id="hcodigo">
                            <input type="hidden" id="hidAcciones">
                            <div class="col-md-12">
                                <label>Año Presupuestal </label> <label style="color:red">(*)</label>
                                <select id="cboAnio" class="form-select">
                                </select>
                            </div>
                        </div> *@
                        <div class="row">
                            <input type="hidden" id="flagEdit">
                            <input type="hidden" id="hcodigo">
                            <input type="hidden" id="hidAcciones">
                            <div class="col-md-4">
                                <label>Año Presupuestal </label> <label style="color:red">(*)</label>
                                <select id="cboAnio" class="form-select">
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label>Codigo Presupuestal </label><label style="color:red">(*)</label>
                                <input type="text" class="form-control" id="txtPresupuestal" />
                            </div>                        
                            <div class="col-md-4">
                                <label>Descripción Presupuestal</label><label style="color:red">(*)</label>
                                <input type="text" class="form-control" id="txtDescripcionPresupuestal" />
                            </div> 
                                        
                        </div>
@* 
                        <div class="row">
                            <div class="col-md-4">
                                <label>Codigo Acciones </label><label style="color:red">(*)</label>
                                <input type="text" class="form-control" id="txtAcciones" />
                            </div>
                            <div class="col-md-4">
                                <label>Descripción Acciones</label><label style="color:red">(*)</label>
                                <input type="text" class="form-control" id="txtDescripcionAcciones" />
                            </div>
                        </div> *@

                        <div class="row">
                            <div class="col-md-4">
                                <label>Estado </label>
                                <input type="text" class="form-control" id="txtEstado" />
                            </div>                        
                            <div class="col-md-4">
                                <label>Activo</label>
                                <select id="cboActivo" class="form-select">
                                    <option value="1">SÍ</option>
                                    <option value="0">NO</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label>Nro de AEI Asociados</label>
                                <input type="text" class="form-control" id="txtTotalSeleccionados" />
                            </div>
                        </div>
                        @* <div class="row" style="padding-top: 10px">
                            <br />
                            <label style="color:red">Datos Obligatorios (*)</label>
                        </div> *@
                    </fieldset>
                    <div class="card mt-3 mb-3">
                        <legend class="float-none w-auto px-3"> Listado de AEI</legend>                       
                        <div class="row">
                            <div class="col-md-12">
                                <table id="gridCentroCostos" class="table table-hover nowrap" style="width:100%">
                                    <thead class="thead-uarm">
                                        <tr>
                                            <th><input type="checkbox" id="chkTodos" /></th>
                                            <th>Codigo AEI</th>
                                            <th>Descripción AEi</th>
                                            <th>Activo</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    </tbody>
                                </table>
                            </div>
                        </div>                    
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnGrabar" class="btn btn-primary"><i class="bi bi-check-lg"></i> Grabar</button>
                    <button type="button" id="btnCerrar" class="btn btn-outline-dark"><i class="bi bi-x-lg"></i> Cerrar</button>
                </div>
            </div>
        </div>
    </div>

</div>


