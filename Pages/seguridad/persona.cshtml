@page
@model  MRE.Pages.seguridad.personaModel
@{
}
<script src="~/app/services/service.catalogoitem.js"></script>
<script src="~/app/services/service.paises.js"></script>
<script src="~/app/services/service.persona.js"></script>
<script src="~/app/pages/seguridad/persona.js"></script>
<style>
    .container-fluid {
        width: 100% !important;
    }

    .container {
        width: 100% !important;
    }
</style>

<div>
    <div class="row">
        <div class="col-md-12">
            <h3 class="titulo">Mantenimiento Personas <i class="bi-newspaper"></i></h3>
        </div>

    </div>

    <div class="accordion" id="accordionExample">
        <div class="card">
            <div class="card-header" id="headingOne">
                <div class="row">
                    <div class="col-md-9   ">
                        <h5 class="mb-0">
                            Búsqueda avanzada
                            <button class="btn btn-light btn-sm " type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                                <i class="bi-arrow-down-square-fill"></i>
                            </button>
                        </h5>
                    </div>
                    <div class="col-md-3 text-end   ">
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button class="btn btn-danger  btn-sm" title="buscar" id="btnBuscar">
                                <i class="bi-search"></i> Buscar
                            </button>
                            <button class="btn  btn-sm btn-dark" id="btnLimpiar">
                                <i class="bi-arrow-clockwise"></i> Limpiar
                            </button>
                        </div>
                    </div>
                    </div>
            </div>

            <div id="collapseOne" class="collapse" aria-labelledby="headingOne" data-bs-parent="#accordionExample">
                <div class="card-body">
                    <div class="row   m-b-a">
                        <div class="col-md-2">
                            <label>Tipo de documento</label>
                            <select id="cboTipoDocumentoFiltro" class="form-control">
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label>N° documento</label>
                            <input class="form-control" type="text" id="txtNumeroDocumentoFiltro">
                        </div>
                        <div class="col-md-3">
                            <label>Nombre</label>
                            <input class="form-control" type="text" id="txtNombreFiltro">
                        </div>
                        <div class="col-md-3">
                            <label>Apellido Paterno</label>
                            <input class="form-control" type="text" id="txtApellidoPaternoFiltro">
                        </div>
                        <div class="col-md-2">
                            <label>Situación</label>
                            <select id="cboSituacionFiltro" class="form-control">
                                <option value="">Todos</option>
                                 <option value="1">Activo</option>
                                <option value="0">Inactivo</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
         

            <div class="container-fluid tablelist">
                        <div class="row listpro">
                    <div class="col-md-6">
                        <h5 class="titwhite">
                            Resultados de búsqueda
                        </h5>
                    </div>
                    <div class="col-md-6 text-end">
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button class="btn btn-light   mt-2  btn-sm" id="btnAgregar" title="Agregar nuevo">
                                <i class="bi bi-file-earmark-plus-fill"></i> Nuevo Registro
                            </button>
                        </div>
                        </div>
                    </div>
           
                    
                        <div class="row">
                            <div class="col-md-12">
                                 <table id="grid" class="table table-striped   table-hover nowrap" style="width:100%">
                                    <thead class="thead-uarm">
                                        <tr>
                                            <th>N°</th>
                                            <th>Tip. Documento</th>
                                            <th>Documento</th>
                                            <th>Nombre</th>
                                            <th>Apellido Paterno</th>
                                            <th>Apellido Materno</th>
                                            <th>País Nacimiento</th>
                                            <th>Estado</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    </tbody>
                                </table>
                            </div>
                        </div>


            </div>
        </div>
    </div>



    <div class="modal fade" id="modalRegistro" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-menu">
                    <h4 class="modal-title" id="mdlTitle">Registrar nuevo</h4>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" title="Cerrar ventana"></button>
                </div>
                <div class="modal-body">
                    <fieldset>
                        <legend> Datos de persona </legend>
                        <div class="row">
                            <input type="hidden" id="flagEdit">
                            <input type="hidden" id="hcodigo">
                            <div class="col-md-4">
                                <label>Tipo documento </label> <label style="color:red">(*)</label>
                                <select id="cboTipoDocumento" class="form-select">
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label>N° documento </label><label style="color:red">(*)</label>
                                <input type="text" class="form-control" id="txtDocumento" />
                            </div>
                            <div class="col-md-4">
                                <label>Nombre </label><label style="color:red">(*)</label>
                                <input type="text" class="form-control" id="txtNombre" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <label>Apellido Paterno </label><label style="color:red">(*)</label>
                                <input type="text" class="form-control" id="txtApellidoPaterno" />
                            </div>
                            <div class="col-md-4">
                                <label>Apellido Materno</label>
                                <input type="text" class="form-control" id="txtApellidoMaterno" />
                            </div>
                            <div class="col-md-4">
                                <label>Sexo </label><label style="color:red">(*)</label>
                                <select id="cboTipoGenero" class="form-select">
                                    <option value="0" selected>Seleccionar</option>
                                    <option value="M">Masculino</option>
                                    <option value="F">Femenino</option> 
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <label>Correo </label><label style="color:red">(*)</label>
                                <input type="text" class="form-control" id="txtCorreo" />
                            </div>
                            <div class="col-md-4">
                                <label>País de Nacimiento </label><label style="color:red">(*)</label>
                                <select id="cboPaisNacimiento" class="form-select">
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label>Fecha de Nacimiento </label><label style="color:red">(*)</label>
                                <input type="date" class="form-control" id="txtFechaNacimiento" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <label>Estado Civil </label><label style="color:red">(*)</label>
                                <select id="cboEstadoCivil" class="form-select">
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label>Teléfono </label>
                                <input type="text" class="form-control" id="txtTelefono" />
                            </div>
                            <div class="col-md-4">
                                <label>Activo</label>
                                <select id="cboActivo" class="form-select">
                                    <option value="1">SÍ</option>
                                    <option value="0">NO</option>
                                </select>
                            </div>
                        </div>
                        <div class="row" style="padding-top: 10px">
                            <br />
                            <label style="color:red">Datos Obligatorios (*)</label>
                        </div>
                    </fieldset>

                </div>
                <div class="modal-footer">
                    <button type="button" id="btnGrabar" class="btn btn-primary"><i class="bi bi-check-lg"></i> Grabar</button>
                    <button type="button" id="btnCerrar" class="btn btn-outline-dark"><i class="bi bi-x-lg"></i> Cerrar</button>
                </div>
            </div>
        </div>
    </div>

</div>