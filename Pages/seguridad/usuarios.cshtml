@page
@model MRE.Pages.seguridad.usuariosModel
@{

<script src="~/app/services/service.catalogoitem.js"></script>}
<script src="~/app/services/service.usuario.js"></script>
<script src="~/app/services/service.persona.js"></script>
<script src="~/app/pages/seguridad/usuario.js"></script>
<style>
    .container-fluid {
        width: 100% !important;
    }

    .container {
        width: 100% !important;
    }
</style>

<div>
    <div class="row">
        <div class="col-md-12">
            <h3 class="titulo">Mantenimiento Usuarios <i class="bi-newspaper"></i></h3>
        </div>

    </div>

    <div class="accordion" id="accordionExample">
        <div class="card">
            <div class="card-header" id="headingOne">
                <div class="row">
                    <div class="col-md-9   ">
                        <h5 class="mb-0">
                            Búsqueda avanzada
                            <button class="btn btn-light btn-sm " type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                                <i class="bi-arrow-down-square-fill"></i>
                            </button>
                        </h5>
                    </div>
                    <div class="col-md-3 text-end   ">
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button class="btn btn-danger  btn-sm" title="buscar" id="btnBuscar">
                                <i class="bi-search"></i> Buscar
                            </button>
                            <button class="btn  btn-sm btn-dark" id="btnLimpiar">
                                <i class="bi-arrow-clockwise"></i> Limpiar
                            </button>
                        </div>
                        </div>
                    </div>
            </div>

            <div id="collapseOne" class="collapse" aria-labelledby="headingOne" data-bs-parent="#accordionExample">
                <div class="card-body">
                    <div class="row m-b-a">
                        <div class="col-md-2">
                            <label>Tipo Documento</label>
                            <select class="form-control" id="cboTipoDocumentoFiltro"></select>
                        </div>
                        <div class="col-md-2">
                            <label>N° Documento</label>
                            <input class="form-control" onkeypress="return soloNumeros(event)" type="text" id="txtNumeroDocumentoFiltro">
                        </div>
                        <div class="col-md-2">
                            <label>Nombres</label>
                            <input class="form-control" type="text" id="txtNombreFiltro">
                        </div>
                        <div class="col-md-3">
                            <label>Apellido Paterno</label>
                            <input class="form-control" type="text" id="txtApellidoPaternoFiltro">
                        </div>
                        <div class="col-md-3">
                            <label>Correo</label>
                            <input class="form-control" type="text" id="txtCorreoFiltro">
                        </div>
                    </div>
                </div>
            </div>


            <div class="container-fluid tablelist">
                <div class="row listpro">
                    <div class="col-md-6">
                        <h5 class="titwhite">
                            Resultados de búsqueda
                        </h5>
                    </div>
                    <div class="col-md-6 text-end">
                        <button class="btn btn-light   mt-2  btn-sm" id="btnAgregar" title="Agregar nuevo">
                            <i class="bi bi-file-earmark-plus-fill"></i> Nuevo Registro
                        </button>
                    </div>
                </div>
           
             
                <div class="row">
                    <div class="col-md-12">
                        <table id="grid" class="table table-striped table-hover nowrap" style="width:100%">
                            <thead class="thead-uarm">
                                <tr>
                                    <th>N°</th>
                                    <th>Tipo Documento</th>
                                    <th>N° Documento</th>
                                    <th>Nombres</th>
                                    <th>Apellido Paterno</th>
                                    <th>Apellido Materno</th>
                                    <th>Correo</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
             

        </div>
    </div>



    <div class="modal fade" id="modalRegistro" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-menu">
                    <h4 class="modal-title" id="mdlTitle">Registrar nuevo</h4>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" title="Cerrar ventana"></button>
                </div>
                <div class="modal-body">

                    <fieldset>
                        <legend>
                            Datos de Usuario
                            <button type="button" class="btn btn-sm-2 btn-dark" id="btnBuscarPersona"><i class="bi bi-search"></i> Buscar Persona</button>
                        </legend>
                        <div class="row">
                            <input type="hidden" id="flagEdit">
                            <input type="hidden" id="hcodigo">
                            <div class="col-md-3">
                                <p class="p-br   ">Número documento</p>
                                <p class="p-br-b" id="lblNumDocumento"></p>

                            </div>
                            <div class="col-md-3">
                                <p class="p-br ">Tipo documento</p>
                                <p class="p-br-b" id="lblTipoDocumento"></p>
                            </div>
                            <div class="col-md-3">
                                <p class="p-br  ">Nombres</p>
                                <p class="p-br-b" id="lblNombres"></p>
                            </div>
                            <div class="col-md-3">
                                <p class="p-br  ">Apellido Paterno</p>
                                <p class="p-br-b" id="lblApellidoPaterno"></p>
                            </div>
                        </div>
                        <div class="row">

                            <div class="col-md-3">
                                <p class="p-br">Apellido Materno</p>
                                <p class="p-br-b" id="lblApellidoMaterno"></p>
                            </div>
                            <div class="col-md-3">
                                <p class="p-br">Correo</p>
                                <p class="p-br-b" id="lblCorreo"></p>
                                <input type="hidden" id="hidPersona" />
                            </div>
                        </div>
                    </fieldset>
                    <div class="row">
                        <div class="col-md-4">
                            <fieldset>
                                <legend>
                                    <div class="form-check form-switch">
                                        <label class="form-check-label" for="switchCheckMre"> Datos de acceso: BackOffice</label>
                                        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckMre" >
                                    </div>
                                </legend>
                                <div class="row" id="divMre">
                                    <div class="col-md-6">
                                        <label>Usuario NT</label>
                                        <input type="text" class="form-control" id="txtUserNT" />
                                    </div>
                                    <div class="col-md-6">
                                        <label>Contraseña</label>
                                        <div class="input-group">
                                            <input  type="password" class="form-control" aria-describedby="btnVerBack" id="txtClaveNT" disabled>
                                            <button class="btn btn-secondary" type="button" id="btnVerBack"><i class="bi bi-eye-fill"></i></button>
                                        </div>
                                        
                                    </div>
                                </div>
                            </fieldset>
                        </div>
                        <div class="col-md-8" >
                            <fieldset>
                                <legend>
                                    <div class="form-check form-switch">
                                        <label class="form-check-label" for="switchCheckEmb">Datos de acceso: Centro Costos</label>
                                        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckEmb">
                                    </div>
                                </legend>
                                <div class="row" id="divEmb">
                                    <div class="col-md-4">
                                        <label>Correo</label>
                                        <input type="email" class="form-control" id="txtCorreo" />
                                    </div>
                                    <div class="col-md-4">
                                        <label>Login</label>
                                        <input type="text" class="form-control" id="txtLogin" />
                                    </div>
                                    <div class="col-md-4">
                                        <label>Clave</label>
                                        <div class="input-group">
                                            <input type="password" class="form-control" aria-describedby="btnVerUsu" id="txtClave" />
                                            <button class="btn btn-secondary" type="button" id="btnVerUsu"><i class="bi bi-eye-fill"></i></button>
                                        </div>
                                      
                                    </div>
                                </div>
                            </fieldset>
                        </div>
                    </div>
                   
                    
                </div>
                <div class="modal-footer">
                   
                    <button type="button" id="btnGrabar" class="btn btn-primary"><i class="bi bi-check-lg"></i> Grabar</button>
                    <button type="button" id="btnCerrar" class="btn btn-outline-dark"><i class="bi bi-x-lg"></i> Cerrar</button>
                </div>
            </div>
        </div>
    </div>


    <div class="modal fade" id="modalBuscarPersona" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-menu">
                    <h4 class="modal-title" id="mdlTitle">Buscar persona</h4>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" title="Cerrar ventana"></button>
                </div>
                <div class="modal-body">
                    <div class="card mt-3 mb-3">
                        <div class="card-header">
                            <div class="row">
                                <div class="col-md-12">
                                    <h5>
                                        Filtros de búsqueda
                                    </h5>
                                </div>

                            </div>
                        </div>
                        <div class="card-body">
                                <div class="row m-b-a">
                                    <div class="col-md-3">
                                        <label>Tip. documento</label>
                                        <select id="cboFiltroBusquedaTipoDocumento" class="form-select">
                                        </select>
                                    </div>
                                    <div class="col-md-2">
                                        <label>N° documento</label>
                                        <input type="text" class="form-control" id="txtFiltroBuquedaNumDoc" />
                                    </div>
                                    <div class="col-md-3">
                                        <label>Nombres</label>
                                        <input type="text" class="form-control" id="txtFiltroBuquedaNombres" />
                                    </div>
                                    <div class="col-md-3">
                                        <label>Apellido Paterno</label>
                                        <input type="text" class="form-control" id="txtFiltroBuquedaApellido" />
                                    </div>
                                    <div class="col-md-1">
                                         <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                        <button id="btnBuscarPersonaModal" class="btn btn-sm btn-dark"><i class="bi bi-search"></i> Buscar</button>
                                             </div>
                                    </div>
                                </div>

                         </div>                        
                    </div>
                    <div class="card mt-3 mb-3">
                        <div class="card-header">
                            <div class="row">
                                <div class="col-md-12">
                                    <h5>
                                        Resultados de búsqueda de Persona
                                    </h5>
                                </div>

                            </div>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-12">
                                    <table id="gridPersona" class="table table-hover nowrap" style="width:100%">
                                        <thead class="thead-uarm">
                                            <tr>
                                                <th>Tipo Documento</th>
                                                <th>N° Documento</th>
                                                <th>Nombre</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                            <button type="button" id="btnCerrarPersona" class="btn btn-outline-dark"><i class="bi bi-x-lg"></i> Cerrar</button>
                </div>
            </div>
        </div>
    </div>
</div>