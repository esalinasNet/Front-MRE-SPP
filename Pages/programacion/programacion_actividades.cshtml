                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 80px;">Acciones</th>
                                        <th style="width: 200px;">Nombre del Trabajador</th>
                                        <th style="width: 150px;">Cargo</th>
                                        <th style="width: 200px;">Clasificador</th>
                                        <th>Enero</th>
                                        <th>Febrero</th>
                                        <th>Marzo</th>
                                        <th>Abril</th>
                                        <th>Mayo</th>
                                        <th>Junio</th>
